{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "main": "out/electron/main/index.js",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 5180 --strictPort",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5180 out/electron/main/index.js && nodemon --watch out/electron/main --watch out/electron/preload --ext js --exec electron .",
    "dev": "concurrently -k -n renderer,main,electron -c cyan,green,magenta \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4180"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "nodemon": "^3.1.10",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  }
}
